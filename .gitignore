# 가상환경 (이게 가장 중요합니다!)
network/

# 파이썬 캐시 파일
__pycache__/
*.py[cod]

# AI 모델 파일 (용량이 커서 따로 관리)
*.pt
*.onnx

# 로그 및 결과 폴더
runs/

# 데이터셋 (구글 드라이브로 공유하기로 한 것들)
dataset/
data/

# OS 관련
.DS_Store
Thumbs.db

# agent 폴더 내의 모든 이미지 및 대용량 파일 제외
hyewon/agent/**/*.jpg
hyewon/agent/**/*.png
hyewon/agent/**/*.mp4
hyewon/agent/**/*.pth
# 혹은 그냥 깔끔하게 결과 폴더 통째로 제외
hyewon/agent/result/